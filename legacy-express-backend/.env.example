# Local docker-compose Postgres (default):
DATABASE_URL="postgresql://itops:itops@localhost:5432/itops_monitor?schema=public"
DIRECT_URL="postgresql://itops:itops@localhost:5432/itops_monitor?schema=public"

# Supabase (get both from Project Settings > Database > Connection string):
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

CHECK_TIMEOUT_MS=10000
CHECK_CONCURRENCY=10
FAILURE_THRESHOLD=2
SSL_EXPIRY_WARNING_DAYS=14

# Optional: leave SMTP_HOST unset to disable email alerts (they'll be logged instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@itops-monitor.local
