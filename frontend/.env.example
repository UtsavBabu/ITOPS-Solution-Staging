VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# Optional — enables the real hCaptcha widget on Login/Register/Forgot
# Password in place of the built-in bot-deterrent challenge. Get a free site
# key at https://www.hcaptcha.com, then also enable hCaptcha under Supabase
# → Authentication → Attack Protection with the matching secret key. See
# DEPLOY.md "Google sign-in & CAPTCHA" for the full setup.
# VITE_HCAPTCHA_SITE_KEY=<your-hcaptcha-site-key>
